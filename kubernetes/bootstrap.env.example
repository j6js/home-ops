# Optional overrides for kubernetes bootstrap tasks.

# Cilium version to install/upgrade.
CILIUM_VERSION=1.18.2

# Optional explicit Kubernetes API endpoint. Autodetected from kubeconfig by default.
# KUBERNETES_SERVICE_HOST=
# KUBERNETES_SERVICE_PORT=6443

# Flux bootstrap target inside this repo.
FLUX_PATH=kubernetes/clusters/main

# Optional explicit Talos node for `task k8s:kubeconfig`.
# TALOS_NODE=2603:c020:....

# GitHub settings are usually inferred from `origin`, but can be pinned here.
# GITHUB_OWNER=j6js
# GITHUB_REPOSITORY=home-ops
# GITHUB_BRANCH=main
# GITHUB_PERSONAL=true
